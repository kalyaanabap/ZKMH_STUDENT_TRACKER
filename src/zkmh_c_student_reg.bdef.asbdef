projection;
strict ( 2 );
use draft;

define behavior for ZKMH_C_STUDENT_REG //alias <alias_name>
{
  use create;
  use update;
  use delete;

  //Expose draft actions
  use action Edit;
  use action Resume;
  use action Activate;
  use action Discard;
  use action Prepare;

  //Expose the custom business actions
  use action markAsActive;
  use action placeOnHold;
  use action markAsCompleted;

}